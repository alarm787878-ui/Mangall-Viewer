{
  "manifest_version": 3,
  "name": "만갤 뷰어 - dcinside Image Viewer",
  "version": "1.3.2.1",
  "description": "디시인사이드에서 이미지를 양면 전체화면으로 편하게 볼 수 있는 뷰어입니다.",
  "permissions": [
    "menus",
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.dcinside.com/*",
    "*://*.dcinside.co.kr/*",
    "*://arca.live/*",
    "*://*.arca.live/*",
    "*://*.blogspot.com/*",
    "*://*.blog.fc2.com/*",
    "*://kone.gg/*",
    "*://*.kone.gg/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "mangall-viewer-fx@codex.local",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "scripts": [
      "browser-api.js",
      "site-registry.js",
      "sites/arca-live.js",
      "sites/blogspot.js",
      "sites/fc2.js",
      "sites/dcinside.js",
      "sites/kone.js",
      "background.js"
    ],
    "preferred_environment": [
      "service_worker",
      "document"
    ],
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "만갤 뷰어",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}
